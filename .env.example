# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA cometa o arquivo .env de verdade no Git.

# String de conexão do PostgreSQL (Supabase, Neon, ou outro provedor gerenciado)
# Formato: postgresql://usuario:senha@host:porta/banco?sslmode=require
DATABASE_URL="postgresql://usuario:senha@host:5432/hubazul?sslmode=require"

# Chave da API da Anthropic (console.anthropic.com) — usada pelo chat de IA
ANTHROPIC_API_KEY="sk-ant-..."
